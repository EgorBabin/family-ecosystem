# COPY TO .env

TRAEFIK_COMMON_NETWORK=common
GALLERY_HOST=gallery.example.com

VITE_NAME=Example web       # Name website and bla-bla
VITE_DOMAIN=Example.com
VITE_PROTOCOL=https://
VITE_ID_PUBLIC_URL=https://id.example.com

LOG_LEVEL= #debug

FRONTEND_URL=https://gallery.example.com

SESSION=gallery_session            # name
SESSION_SECRET=change_me_to_long_random_secret # для подписи сессий

# s3
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# upload limits (backend)
MAX_UPLOAD_MB=20

# rabbitmq + worker
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_QUEUE=gallery.photo.jobs
PHOTO_WORKER_PREFETCH=1
PHOTO_WORKER_RETRY_MS=3000
GALLERY_SOFT_DELETE_RETENTION_DAYS=30
GALLERY_SOFT_DELETE_SWEEP_INTERVAL_MS=3600000
GALLERY_SOFT_DELETE_DELETE_CONCURRENCY=8

# postgreSql
PG_USER=postgres
PG_PASSWORD=password
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=gallery

# first user 
APP_INIT_USERNAME=admin
APP_INIT_EMAIL=admin@gmail.com         # a@gmail.com,b@yandex.ru
APP_INIT_ROLE=admin
APP_INIT_TG_ID=123456
APP_INIT_IS_ACTIVE=true

# logger
TG_BOT_TOKEN=1234567890:bla_Bla_BLa12
TG_CHAT_ID=-100123
