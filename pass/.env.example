# Copy to .env
TRAEFIK_COMMON_NETWORK=common

# Public host used by Traefik and Vaultwarden
VAULTWARDEN_HOST=pass.example.com
VAULTWARDEN_DOMAIN=https://pass.example.com

# Security-first defaults
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=false
VAULTWARDEN_DISABLE_ADMIN_TOKEN=true
# docker run --rm -it vaultwarden/server:latest /vaultwarden hash
VAULTWARDEN_ADMIN_TOKEN=''
# CSV CIDRs/IPs allowed to open /admin (default denies remote access)
VAULTWARDEN_ADMIN_ALLOW_IPS=127.0.0.1/32
VAULTWARDEN_LOG_LEVEL=warn

# SMTP (email support for invitations, password hints, etc.)
# SECURITY: starttls | force_tls | off
# AUTH MECHANISM (optional): Plain | Login | Xoauth2
VAULTWARDEN_SMTP_HOST=smtp.example.com
VAULTWARDEN_SMTP_FROM=vaultwarden@example.com
VAULTWARDEN_SMTP_FROM_NAME=Vaultwarden
VAULTWARDEN_SMTP_PORT=587
VAULTWARDEN_SMTP_SECURITY=starttls
VAULTWARDEN_SMTP_USERNAME=vaultwarden@example.com
VAULTWARDEN_SMTP_PASSWORD=change-me
VAULTWARDEN_SMTP_TIMEOUT=15
VAULTWARDEN_SMTP_AUTH_MECHANISM=

# Timezone used for nightly DB backups
TZ=Europe/Moscow

# Backup policy:
# - backups run every night at 03:00 (cron format)
# - if a backup archive is <= threshold MB, keep backups for 60 days
# - if a backup archive is > threshold MB, keep backups for 30 days
VAULTWARDEN_BACKUP_SCHEDULE="0 3 * * *"
VAULTWARDEN_BACKUP_RETENTION_SHORT_DAYS=30
VAULTWARDEN_BACKUP_RETENTION_LONG_DAYS=60
VAULTWARDEN_BACKUP_SIZE_THRESHOLD_MB=100
